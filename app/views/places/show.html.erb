<h1><%= @place.name %></h1>

<p><%= link_to "Back to places", places_path %></p>
<p><%= link_to "Add a new entry", new_entry_path(place_id: @place.id) %></p>

<h2>Entries</h2>
<ul>
  <% @entries.each do |entry| %>
    <li>
      <strong><%= entry.title %></strong> (<%= entry.occurred_on %>)<br>
      <%= entry.description %>
    </li>
  <% end %>
</ul>