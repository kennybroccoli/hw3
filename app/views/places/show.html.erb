<h1><%= @place.name %></h1>

<p><%= link_to "Back to places", places_path %></p>

<h2>Entries</h2>
<% @entries.each do |entry| %>
  <div>
    <strong><%= entry.title %></strong><br>
    <%= entry.description %><br>
    <small><%= entry.occurred_on %></small>
  </div>
<% end %>

<p><%= link_to "New Post", new_entry_path(place_id: @place.id) %></p>